/*
 * LINK: https://cses.fi/problemset/task/3359
 * NAME: Minimal Grid Path
*/

#include <bits/stdc++.h>

using namespace std;
typedef long long ll;
typedef unsigned long long ull;

/*
    REASON:
*/

bool dp_dir[3002][3002] = {0}; // 0 = up, 1 = right
char lett[3001][3001] = {0};

void dpI(int n) {
    for (int i = 1; i <= n; i++) {
        for (int j = 1; j <= n; j++) {

            ull letterl = lett[i][j+1];
            ull letterr = lett[i+1][j];

            if (letterl < letterr) dp_dir[i][j] = 1;
            else                   dp_dir[i][j] = 0;
        }
    }
}

int main(void) {
    int n; cin >> n;

    for (int i = 0; i <= n; i++) {
        lett[n+1][i] = CHAR_MAX;
        lett[i][n+1] = CHAR_MAX;
    }

    for (int i = 1; i <= n; i++) {
        string str; cin >> str;
        for (int j = 1; j <= n; j++) {
            lett[i][j] = str[j-1];
        }
    }

    dpI(n);

    string res;
    for (int i = n, j = n; j > 0 && i > 0; ) {
        res = res + lett[i][j] ;
        if (dp_dir[i][j]) j--;
        else              i--;
    }

    cout << res << endl;
    return 0;
}
